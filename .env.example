# ===========================================
# Taqon Electrico Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (PostgreSQL)
DATABASE_URL=postgres://taqon:taqon_password@db:5432/taqon_db
POSTGRES_DB=taqon_db
POSTGRES_USER=taqon
POSTGRES_PASSWORD=taqon_password

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Email (use console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Taqon Electrico <noreply@taqon.co.zw>

# Paynow Payment Gateway
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RETURN_URL=http://localhost:5173/payment/return
PAYNOW_RESULT_URL=http://localhost:8000/api/v1/payments/webhook/paynow/

# Stripe Payment Gateway
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# DigitalOcean Spaces (for static/media in production)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_REGION=nyc3
DO_SPACES_CDN=
DO_SPACES_STATIC=true

# AWS S3 (alternative to DO Spaces)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Sentry (production error tracking)
SENTRY_DSN=

# Exchange Rate
USD_TO_ZWG_RATE=25.0
